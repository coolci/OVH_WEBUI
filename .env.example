# ═══════════════════════════════════════════════════════════
# OVH_WEBUI · Docker / Linux 部署环境变量
# cp .env.example .env   或运行 scripts/linux-oneclick-deploy.sh
# 切勿提交真实 .env 到 git
# ═══════════════════════════════════════════════════════════

# —— 网关鉴权（前端登录 / 脚本 X-API-Key）——
API_SECRET_KEY=change-me-to-a-long-random-string
ENABLE_API_KEY_AUTH=true

# —— 时区 ——
TZ=Asia/Shanghai

# —— 仅 HTTP 模式端口（无 SSL 时）——
FRONTEND_PORT=8080
BACKEND_PORT=19998

# ═══════════════════════════════════════════════════════════
# SSL + Telegram Webhook（公网生产）
# 域名 A 记录 → 服务器公网 IP；放行 80/443
# ═══════════════════════════════════════════════════════════

# 必填（启用 SSL 时）：你的域名，不要带 https://
# DOMAIN=ovh.example.com

# Let's Encrypt 通知邮箱
# ACME_EMAIL=ops@example.com

# 公网根 URL（一键脚本会自动写成 https://$DOMAIN）
# PUBLIC_BASE_URL=https://ovh.example.com

# Telegram Webhook 完整地址（设置时用域名根即可，后端会补全路径）：
#   https://ovh.example.com/api/telegram/webhook
# 该路径免 API Key，仅 Telegram 服务器 POST

# 可选：烟测目标机
# SMOKE_ALLOWED_SERVER=
