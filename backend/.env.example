# ═══════════════════════════════════════════════════════════
# OVH_WEBUI 后端环境变量样板
# 复制为 .env 后修改（.env 已被 gitignore，切勿提交）
#   Windows:  copy .env.example .env
#   或运行:   ..\scripts\init-first-run.ps1
# ═══════════════════════════════════════════════════════════

# HTTP
PORT=19998
LISTEN_HOST=
GIN_MODE=release
DEBUG=false

# 网关鉴权：前端 / 脚本请求头 X-API-Key 必须与此一致
# 生产环境请使用足够长的随机串（init 脚本会自动生成）
API_SECRET_KEY=change-me-to-a-long-random-string
ENABLE_API_KEY_AUTH=true

# 持久化目录（账户 / 队列 / 缓存 / 日志），相对 backend 工作目录或绝对路径
DATA_DIR=data

# 说明：
# - OVH Application Key / Secret / Consumer Key 请在前端「设置 → OVH 账户」添加
#   （多账户模型，不再依赖此处写死单套凭据）
# - Telegram Token / Chat ID 可在前端「设置 → Telegram」配置
# - 线上巡检已下线，无需 INSPECTION_* 变量
